{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "dist",
    "types": ["node"],
    "typeRoots": ["../node_modules/@types", "./node_modules/@types"]
  },
  "include": [
    "src/**/*",
    "db.ts"
  ]
}
